<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.mql5.devkit</id>
    <version>0.1.0</version>
    <vendor email="" url="https://github.com/yourname/mql5-devkit">MQL5 DevKit</vendor>

    <name>MQL5 DevKit</name>

    <description><![CDATA[
    Complete MQL5 development environment for IntelliJ IDEA.<br>
    <ul>
      <li>Syntax highlighting for MQL4/MQL5</li>
      <li>Code completion &amp; documentation</li>
      <li>One-click compilation via MetaEditor</li>
      <li>Inline error annotations</li>
      <li>Project templates &amp; file wizards</li>
      <li>clangd integration for advanced IntelliSense</li>
    </ul>
    <em>Based on MQL Idea 2 by Investflow and Lime MQL Editing</em>
  ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Application-level services -->
        <applicationService serviceImplementation="ru.investflow.mqlidea2.settings.Mql5Settings"/>
        <applicationService serviceImplementation="ru.investflow.mqlidea2.settings.MQL4PluginSettingsImpl"/>

        <!-- Project-level services -->
        <projectService serviceImplementation="ru.investflow.mqlidea2.ui.Mql5BuildLogService"/>
        <projectService serviceImplementation="ru.investflow.mqlidea2.compiler.Mql5CompilationResultCache"/>

        <!-- Notification groups -->
        <notificationGroup id="MQL5DevKit" displayType="BALLOON"/>

        <!-- Language & File Type -->
        <fileType name="MQL4 File"
                  implementationClass="ru.investflow.mqlidea2.MQL4FileType"
                  fieldName="INSTANCE"
                  language="MQL4"
                  extensions="mq4;mqh;mql4;mq5;mql5"
        />

        <!-- Parser -->
        <lang.parserDefinition language="MQL4" implementationClass="ru.investflow.mqlidea2.parser.MQL4ParserDefinition"/>

        <!-- Editor Features -->
        <lang.syntaxHighlighterFactory language="MQL4"
                                       implementationClass="ru.investflow.mqlidea2.editor.MQL4SyntaxHighlighter$MQL4SyntaxHighlighterFactory"/>
        <colorSettingsPage implementationClass="ru.investflow.mqlidea2.editor.MQL4ColorSettingsPage"/>
        <lang.commenter language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4Commenter"/>
        <lang.documentationProvider language="MQL4"
                                    implementationClass="ru.investflow.mqlidea2.doc.MQL4DocumentationProvider"/>
        <lang.braceMatcher language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4BraceMatcher"/>
        <lang.foldingBuilder language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4FoldingBuilder"/>
        <typedHandler language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4TypedHandler"/>

        <!-- Quote Handler -->
        <editorQuoteHandler language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4QuoteHandler"/>

        <!-- Enter Handler -->
        <enterHandlerDelegate implementation="ru.investflow.mqlidea2.editor.MQL4EnterHandlerDelegate"/>

        <!-- Line Markers -->
        <codeInsight.lineMarkerProvider language="MQL4"
                                        implementationClass="ru.investflow.mqlidea2.editor.MQL4LineMarkerProvider"/>

        <!-- Highlight Usages -->
        <highlightUsagesHandlerFactory implementation="ru.investflow.mqlidea2.editor.MQL4HighlightUsagesHandlerFactory"/>

        <!-- File Icon Provider -->
        <fileIconProvider implementation="ru.investflow.mqlidea2.editor.MQL4FileIconProvider"/>

        <!-- Code Formatter -->
        <lang.formatter language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4CodeFormatter"/>

        <!-- Import Optimizer -->
        <lang.importOptimizer language="MQL4" implementationClass="ru.investflow.mqlidea2.editor.MQL4ImportOptimizer"/>

        <!-- Spellchecker -->
        <spellchecker.support language="MQL4"
                              implementationClass="ru.investflow.mqlidea2.editor.MQL4SpellcheckingStrategy"/>

        <!-- Surround With -->
        <lang.surroundDescriptor language="MQL4"
                                 implementationClass="ru.investflow.mqlidea2.editor.MQL4SurroundWithHandler"/>

        <!-- Code Style Settings -->
        <codeStyleSettingsProvider implementation="ru.investflow.mqlidea2.editor.MQL4CodeStyleSettingsProvider"/>
        <langCodeStyleSettingsProvider
                implementationClass="ru.investflow.mqlidea2.editor.MQL4CodeStyleSettingsProvider"/>

        <!-- Code Completion -->
        <completion.contributor language="MQL4"
                                implementationClass="ru.investflow.mqlidea2.editor.codecompletion.MQL4CompletionContributor"/>

        <!-- Parameter Info -->
        <codeInsight.parameterInfo language="MQL4"
                                   implementationClass="ru.investflow.mqlidea2.editor.MQL4ParameterInfoHandler"/>

        <!-- Live Templates -->
        <defaultLiveTemplates file="/liveTemplates/MQL5.xml"/>
        <liveTemplateContext implementation="ru.investflow.mqlidea2.editor.MQL4LiveTemplateContext"/>

        <!-- Error Annotations from MetaEditor -->
        <externalAnnotator language="MQL4"
                           implementationClass="ru.investflow.mqlidea2.compiler.Mql5ExternalAnnotator"/>

        <!-- SDK -->
        <sdkType implementation="ru.investflow.mqlidea2.sdk.MQL4SdkType"/>

        <!-- Module Type for new MQL5 projects -->
        <moduleType id="MQL5_MODULE" implementationClass="ru.investflow.mqlidea2.action.Mql5ModuleBuilder$Mql5ModuleType"/>

        <!-- Build Runner (existing) -->
        <programRunner implementation="ru.investflow.mqlidea2.runconfig.MQL4CompilerRunner"/>
        <runConfigurationProducer implementation="ru.investflow.mqlidea2.runconfig.MQL4RunCompilerConfigurationProducer"/>
        <configurationType implementation="ru.investflow.mqlidea2.runconfig.MQL4RunCompilerConfigurationType"/>

        <!-- Settings -->
        <projectConfigurable id="settings.mql5" parentId="tools"
                             instance="ru.investflow.mqlidea2.settings.Mql5SettingsConfigurable"
                             displayName="MQL5 DevKit"/>

        <!-- Inspections -->
        <localInspection language="MQL4" groupName="MQL5 inspections" enabledByDefault="true" level="WARNING"
                         displayName="Preprocessor #property element"
                         implementationClass="ru.investflow.mqlidea2.inspection.PreprocessorPropertyInspection"/>
        <localInspection language="MQL4" groupName="MQL5 inspections" enabledByDefault="true" level="WEAK WARNING"
                         displayName="Missing entry point function"
                         implementationClass="ru.investflow.mqlidea2.inspection.MQL5EntryPointInspection"/>
        <localInspection language="MQL4" groupName="MQL5 inspections" enabledByDefault="true" level="WARNING"
                         displayName="Duplicate #include directive"
                         implementationClass="ru.investflow.mqlidea2.inspection.MQL5DuplicateIncludeInspection"/>

        <!-- Structure View -->
        <lang.psiStructureViewFactory language="MQL4"
                                      implementationClass="ru.investflow.mqlidea2.structure.MQL4StructureViewBuilderFactory"/>

        <!-- Indexing -->
        <stubElementTypeHolder class="ru.investflow.mqlidea2.psi.stub.MQL4StubElements"/>
        <stubIndex implementation="ru.investflow.mqlidea2.index.MQL4ClassNameIndex"/>
        <stubIndex implementation="ru.investflow.mqlidea2.index.MQL4FunctionNameIndex"/>

        <gotoClassContributor implementation="ru.investflow.mqlidea2.index.MQL4GotoClassContributor"/>
        <gotoSymbolContributor implementation="ru.investflow.mqlidea2.index.MQL4GotoSymbolContributor"/>
        <gotoDeclarationHandler implementation="ru.investflow.mqlidea2.index.MQL4GotoDeclarationHandler"/>

        <!-- Find Usages -->
        <lang.findUsagesProvider language="MQL4"
                                 implementationClass="ru.investflow.mqlidea2.index.MQL4FindUsagesProvider"/>

        <!-- Rename -->
        <renameHandler implementation="ru.investflow.mqlidea2.refactor.MQL4RenameProcessor"/>

        <!-- Tool Window -->
        <toolWindow id="MQL5 Build" anchor="bottom"
                    factoryClass="ru.investflow.mqlidea2.ui.Mql5ToolWindowFactory"
                    icon="AllIcons.Actions.Compile"/>

    </extensions>

    <applicationListeners>
        <listener class="ru.investflow.mqlidea2.compiler.Mql5CompileOnSaveHandler"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>

    <actions>
        <group id="MQL5.NewGroup" text="MQL5" popup="true">
            <action id="MQL5.NewEA" class="ru.investflow.mqlidea2.action.CreateMQL5FileAction$Ea"/>
            <action id="MQL5.NewIndicator" class="ru.investflow.mqlidea2.action.CreateMQL5FileAction$Indicator"/>
            <action id="MQL5.NewScript" class="ru.investflow.mqlidea2.action.CreateMQL5FileAction$Script"/>
            <action id="MQL5.NewService" class="ru.investflow.mqlidea2.action.CreateMQL5FileAction$Service"/>
            <action id="MQL5.NewInclude" class="ru.investflow.mqlidea2.action.CreateMQL5FileAction$Include"/>
            <separator/>
            <action id="MQL5.NewMQ4" class="ru.investflow.mqlidea2.action.CreateMQL5FileAction$Mq4"/>
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </group>

        <!-- Compile Actions -->
        <action id="MQL5.CompileCurrent"
                class="ru.investflow.mqlidea2.compiler.Mql5BuildAction"
                text="Compile MQL5" description="Compile current MQL5 file with MetaEditor">
            <add-to-group group-id="BuildMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="F7"/>
        </action>

        <!-- Run on Chart -->
        <action id="MQL5.RunOnChart"
                class="ru.investflow.mqlidea2.compiler.Mql5RunOnChartAction"
                text="Run on Chart" description="Compile and run in MetaTrader 5 terminal">
            <add-to-group group-id="BuildMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="F5"/>
        </action>

        <!-- clangd Setup -->
        <action id="MQL5.SetupClangd"
                class="ru.investflow.mqlidea2.clangd.ClangdSetupAction"
                text="Setup clangd for MQL5" description="Generate .clangd configuration for MQL5 IntelliSense">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- Open in MetaEditor -->
        <action id="MQL5.OpenInMetaEditor"
                class="ru.investflow.mqlidea2.action.OpenInMetaEditorAction"
                text="Open in MetaEditor" description="Open current file in MetaEditor 5">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
